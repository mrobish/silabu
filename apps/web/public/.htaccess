# SPA fallback — all non-file routes serve index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/api
  RewriteRule . /index.html [L]
</IfModule>

# index.html — NEVER cache (always fetch fresh, ensures latest bundle hash)
<Files "index.html">
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header set Pragma "no-cache"
</Files>

# Fingerprinted assets (Vite outputs index-[hash].js / index-[hash].css)
# Safe to cache long-term — hash changes on each build, filename changes with it
<FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|webp|ico)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Protect hidden/sensitive files
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
